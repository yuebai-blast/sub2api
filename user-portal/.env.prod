# user-portal 发版构建配置（仅由 build:prod 脚本的 vite build --mode prod 加载）
# 注意：故意命名为 .env.prod 而非 .env.production——后者会被默认 `vite build`（mode=production）
# 自动加载，导致本地构建也吃到发版配置。用自定义 mode "prod" 后，只有显式 --mode prod 才读它。
# 改这里需重新发版构建（mise run user-portal-image / 发版）才生效。

# 语言模式（控制门户的语言切换功能）：
#   AUTO   显示语言切换入口，按 localStorage > 浏览器语言 > 中文 自动检测
#   zh-CN  锁定为简体中文，并隐藏语言切换入口
#   en-US  锁定为英文，并隐藏语言切换入口
VITE_PORTAL_LOCALE=AUTO

# 分布卡片文案模式（控制仪表盘右侧分布卡片的标题与各格文案）：
#   MODEL        模型厂商分布：标题"模型厂商分布"，四格为 Claude / GPT / Gemini / Other
#   APPLICATION  应用类型分布：标题"应用类型分布"，四格为 Text / Vision / Voice / Other
VITE_PORTAL_DISTRIBUTION_MODE=MODEL
