# ====== 重要：网络配置说明 ======
# Caddy 必须与 backend / user-portal 容器运行在同一个 Docker 网络中，
# 才能通过服务名（backend:8080、user-portal:80）进行 DNS 解析和通信。
# 如果 Caddy 容器网络隔离，这些服务名会无法解析导致反代失败。
#
# 下面的 *.example.com 域名是示例占位符，实际部署请替换为真实域名。

# 用户门户（独立 SPA 镜像）
portal.example.com {
    reverse_proxy user-portal:80
}

# 平台主域：API + 内嵌 admin 前端均由 backend 提供
app.example.com {
    # 网关/接口路径直达后端
    @api path /api/* /v1/* /v1beta/* /backend-api/* /antigravity/* /setup/* /responses /responses/* /images/* /health
    reverse_proxy @api backend:8080

    # 其余（内嵌 frontend）也由 backend 提供
    reverse_proxy backend:8080
}
